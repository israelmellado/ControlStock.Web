@model ControlStock.Web.Models.Producto

@{
    ViewData["Title"] = "Detalle Producto";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📦 Detalle del Producto</h2>

    <a asp-action="Index" class="btn btn-outline-secondary">
        ← Volver
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <h4 class="mb-3">@Model.Nombre</h4>

        <div class="row">

            <div class="col-md-3">
                <strong>Precio:</strong><br />
                @Model.Precio €
            </div>

            <div class="col-md-3">
                <strong>Stock Actual:</strong><br />

                @if (Model.StockActual <= Model.StockMinimo)
                {
                    <span class="badge bg-danger">
                        🚨 @Model.StockActual
                    </span>
                }
                else
                {
                    <span class="badge bg-success">
                        @Model.StockActual
                    </span>
                }
            </div>

            <div class="col-md-3">
                <strong>Stock Mínimo:</strong><br />
                @Model.StockMinimo
            </div>

            <div class="col-md-3">
                <strong>Categoría:</strong><br />
                <span class="badge bg-secondary">
                    @Model.Categoria?.Nombre
                </span>
            </div>

        </div>

    </div>
</div>