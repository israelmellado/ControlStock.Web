@model ControlStock.Web.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>✏️ Editar Producto</h2>

    <a asp-action="Index" class="btn btn-outline-secondary">
        ← Volver
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label">Precio</label>
                    <input asp-for="Precio" class="form-control" />
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label">Stock Actual</label>
                    <input asp-for="StockActual" class="form-control" />
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label">Stock Mínimo</label>
                    <input asp-for="StockMinimo" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Categoría</label>

                    <select asp-for="CategoriaId"
                            class="form-control"
                            asp-items="@(new SelectList(ViewBag.Categorias, "Id", "Nombre"))">
                    </select>
                </div>

            </div>

            <button type="submit" class="btn btn-primary">
                💾 Guardar cambios
            </button>

        </form>

    </div>
</div>
