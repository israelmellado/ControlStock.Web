@model IEnumerable<ControlStock.Web.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

@* HEADER *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold">📦 Gestión de Productos</h2>

    <a asp-action="Create" class="btn btn-success">
        + Nuevo Producto
    </a>
</div>

@* BUSCADOR *@
<form method="get" asp-action="Index" class="mb-3">
    <div class="input-group shadow-sm">
        <input type="text"
               name="buscar"
               value="@ViewBag.BuscarActual"
               class="form-control"
               placeholder="Buscar producto..." />

        <button class="btn btn-primary">
            🔍 Buscar
        </button>

        <input type="hidden" name="orden" value="@ViewBag.OrdenActual" />
    </div>
</form>

@* TABLA *@
<div class="card shadow-sm">
    <div class="card-body p-0">

        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a class="text-white text-decoration-none"
                           asp-action="Index"
                           asp-route-orden="@(ViewBag.OrdenActual == "nombre" ? "nombre_desc" : "nombre")">
                            Nombre
                        </a>
                    </th>

                    <th>Precio</th>

                    <th>
                        <a class="text-white text-decoration-none"
                           asp-action="Index"
                           asp-route-orden="@(ViewBag.OrdenActual == "stock" ? "stock_desc" : "stock")">
                            Stock
                        </a>
                    </th>

                    <th>Categoría</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>

                        @* NOMBRE *@
                        <td class="fw-semibold">
                            @item.Nombre
                        </td>

                        @* PRECIO *@
                        <td>
                            @item.Precio.ToString("0.00") €
                        </td>

                        @* STOCK CON BADGES *@
                        <td>
                            @if (item.StockActual <= item.StockMinimo)
                            {
                                <span class="badge bg-danger">
                                    🚨 @item.StockActual
                                </span>
                            }
                            else if (item.StockActual <= item.StockMinimo * 2)
                            {
                                <span class="badge bg-warning text-dark">
                                    ⚠ @item.StockActual
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">
                                    @item.StockActual
                                </span>
                            }
                        </td>

                        @* CATEGORÍA *@
                        <td>
                            <span class="badge bg-secondary">
                                @item.Categoria?.Nombre
                            </span>
                        </td>

                        @* ACCIONES *@
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-primary">
                                Editar
                            </a>

                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-info">
                                Ver
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger">
                                Borrar
                            </a>
                        </td>

                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@* PAGINACIÓN *@
<div class="d-flex justify-content-center mt-3">
    <nav>
        <ul class="pagination">

            @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
            {
                <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pagina="@i"
                       asp-route-orden="@ViewBag.OrdenActual"
                       asp-route-buscar="@ViewBag.BuscarActual">
                        @i
                    </a>
                </li>
            }

        </ul>
    </nav>
</div>