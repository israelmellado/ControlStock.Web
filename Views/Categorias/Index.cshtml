@model IEnumerable<ControlStock.Web.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">🗂 Categorías</h2>

    <a class="btn btn-primary" asp-action="Create">
        + Nueva Categoría
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">

        <table class="table table-hover table-striped mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Productos</th>
                    <th class="text-end" style="width:220px;">Acciones</th>
                </tr>
            </thead>

            <tbody>
            @foreach (var item in Model)
            {
                var count = item.Productos?.Count ?? 0;

                <tr>
                    <td>
                        <span class="fw-semibold">@item.Nombre</span>
                    </td>

                    <td>
                        @if (count == 0)
                        {
                            <span class="badge bg-secondary">0 productos</span>
                        }
                        else if (count < 5)
                        {
                            <span class="badge bg-warning text-dark">
                                @count productos
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                @count productos
                            </span>
                        }
                    </td>

                    <td class="text-end">
                        <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id">
                            Editar
                        </a>

                        <a class="btn btn-sm btn-info text-white" asp-action="Details" asp-route-id="@item.Id">
                            Ver
                        </a>

                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id">
                            Eliminar
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>

    </div>
</div>